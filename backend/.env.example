# Servidor
PORT=3005

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=dbbid
# Timeouts / pool (útil com banco remoto, ex.: Azure MySQL)
# DB_CONNECT_TIMEOUT_MS=30000
# DB_POOL_LIMIT=10
# DB_POOL_MAX_IDLE=8
# DB_POOL_IDLE_MS=120000

# Azure AD — tenant principal
AZURE_TENANT_ID=seu-tenant-id
AZURE_CLIENT_ID=seu-client-id
AZURE_CLIENT_SECRET=seu-client-secret

# Azure AD — tenant secundário (opcional)
AZURE_TENANT_ID_2=
AZURE_CLIENT_ID_2=
AZURE_CLIENT_SECRET_2=

# JWT — gere um segredo forte (ex: openssl rand -hex 64)
JWT_SECRET=seu-jwt-secret-aqui

# URL pública da aplicação (imagens em e-mails, integrações)
API_PUBLIC_URL=https://bid.allianzparque.intra

# CORS — origens permitidas, separadas por vírgula
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
