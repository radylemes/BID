# Nginx — bid.allianzparque.com.br
# Site a funcionar com proxy 4201 (ng serve) + assets/vídeo servidos do disco.

server
{
    listen 80;
    listen 443 ssl http2;
    server_name bid.allianzparque.com.br;

    root /www/server/BID/frontend/dist/frontend/browser;
    index index.html index.htm default.htm default.html;

    # SSL
    ssl_certificate     /www/server/panel/vhost/cert/BIDfrontend/fullchain.pem;
    ssl_certificate_key /www/server/panel/vhost/cert/BIDfrontend/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers EECDH+CHACHA20:EECDH+AES128:EECDH+AES256:!MD5:!aNULL:!eNULL;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    error_page 497 https://$host$request_uri;

    if ($server_port !~ 443) {
        rewrite ^(/.*)$ https://$host$1 permanent;
    }

    access_log /www/wwwlogs/BIDfrontend.log;
    error_log  /www/wwwlogs/BIDfrontend.error.log;

    location ~ /\.(?!well-known).* {
        deny all;
        return 404;
    }

    location ~* /(LICENSE|README\.md|package(-lock)?\.json)$ {
        return 404;
    }

    location ^~ /.well-known/ {
        root /www/server/BID/frontend;
    }

    location ^~ /uploads/ {
        alias /www/server/BID/backend/uploads/;
        access_log off;
        expires 7d;
        add_header Cache-Control "public";
    }

    # IMPORTANTE: antes do "location /" com proxy 4201
    # Vídeo de login (~70 MB) e restantes assets — direto do build, sem passar pelo ng serve
    location ^~ /assets/ {
        root /www/server/BID/frontend/dist/frontend/browser;
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public";
        access_log off;
        gzip off;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3005;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 30s;
        proxy_send_timeout 30s;
        proxy_read_timeout 120s;
        limit_except GET POST PUT PATCH DELETE OPTIONS { deny all; }
    }

    location / {
        proxy_pass http://127.0.0.1:4201;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 30s;
        proxy_send_timeout 30s;
        proxy_read_timeout 120s;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
    }

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
}
